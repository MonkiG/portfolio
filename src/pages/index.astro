---
import BaseLayout from '../layouts/BaseLayout.astro'
import ExperienceSection from '../components/ExperienceSection.astro'
import Hero from '../components/Hero.astro'
import LanguagesSection from '../components/LanguagesSection.astro'
import ProjectsSection from '../components/ProjectsSection.astro'
---

<BaseLayout>
    <main class="shell">
        <Hero />

        <section class="section-grid" aria-label="Portfolio sections">
            <ExperienceSection />
            <LanguagesSection />
            <ProjectsSection />
        </section>
    </main>

    <script src="/main.js" is:inline></script>
</BaseLayout>

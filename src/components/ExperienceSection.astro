---
import SectionHeading from './SectionHeading.astro'

const experience = [
    {
        period: 'March 2025 - Present',
        role: 'Web Developer',
        organization: 'Tafer Resorts',
        url: 'https://www.taferresorts.com/',
    },
    {
        period: 'March 2024 - August 2024',
        role: 'Web Developer - Social Service Intern',
        organization: 'Centro Universitario de la Costa',
        url: 'https://www.cuc.udg.mx/',
    },
]
---

<section class="panel experience" aria-labelledby="experience-title">
    <SectionHeading number="01" title="Experience" id="experience-title" />
    <ol class="timeline">
        {experience.map((item) => (
            <li>
                <time>{item.period}</time>
                <div>
                    <strong>{item.role}</strong>
                    <a href={item.url} target="_blank">{item.organization}</a>
                </div>
            </li>
        ))}
    </ol>
</section>

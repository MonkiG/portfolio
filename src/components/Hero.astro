---
const {
  eyebrow,
  title,
  introPrefix,
  universityName,
  universityUrl,
  introSuffix,
  actionsLabel,
  links,
} = Astro.props;
---

<section class="hero" aria-labelledby="intro-title">
  <div class="hero-copy">
    <p class="eyebrow">{eyebrow}</p>
    <h1 id="intro-title">{title}</h1>
    <p class="lede">
      {introPrefix} <a href={universityUrl} target="_blank">{universityName}</a>,
      {introSuffix}
    </p>
    <div class="hero-actions" aria-label={actionsLabel}>
      {links.map((link) => (
        <a class:list={["button", { primary: link.primary }]} rel="me" href={link.href} target="_blank">
          {link.label}
        </a>
      ))}
    </div>
  </div>
</section>

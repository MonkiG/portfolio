---
import SectionHeading from "./SectionHeading.astro";

const { number, title, description, ariaLabel, items } = Astro.props;
---

<section class="panel languages" aria-labelledby="languages-title">
  <SectionHeading number={number} title={title} id="languages-title" />
  <p>{description}</p>
  <ul class="language-list" aria-label={ariaLabel}>
    {items.map((language) => <li>{language}</li>)}
  </ul>
</section>

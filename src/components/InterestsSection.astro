---
import SectionHeading from "./SectionHeading.astro";

const { number, title, description, ariaLabel, items } = Astro.props;
---

<section class="panel interests" aria-labelledby="interests-title">
  <SectionHeading number={number} title={title} id="interests-title" />
  <p>{description}</p>
  <ul class="language-list" aria-label={ariaLabel}>
    {items.map((interest) => <li>{interest}</li>)}
  </ul>
</section>

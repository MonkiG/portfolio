---
import SectionHeading from './SectionHeading.astro'

const { number, title, loading, empty, error, visitWebsiteLabel, viewRepositoryLabel, gifAlt } = Astro.props
---

<section class="panel projects" aria-labelledby="projects-title">
    <SectionHeading number={number} title={title} id="projects-title" className="project-heading" />
    <ul
        id="github-projects"
        class="project-list"
        aria-live="polite"
        data-empty={empty}
        data-error={error}
        data-website-label={visitWebsiteLabel}
        data-repository-label={viewRepositoryLabel}
    >
        <li class="muted">{loading}</li>
    </ul>
    <figure class="projects-gif">
        <img
            src="https://media1.giphy.com/media/v1.Y2lkPTc5MGI3NjExdDExbWlyNTk5NW1paDhoN2lkcGVycHU4YzZ3NGk1ZXA5ZGhuYnhrcSZlcD12MV9pbnRlcm5hbF9naWZfYnlfaWQmY3Q9Zw/QMHoU66sBXqqLqYvGO/giphy.gif"
            alt={gifAlt}
        />
    </figure>
</section>
